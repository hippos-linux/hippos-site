  <script>
    const btn = document.getElementById('btn');
    if (btn) {
      btn.addEventListener('click', async () => {
        const err = document.getElementById('err');
        btn.disabled = true;
        btn.textContent = 'Loading…';
        try {
          const res = await fetch('/api/download');
          if (res.ok) {
            const { url, uploadedAt } = await res.json();
            err.style.display = 'none';
            btn.style.display = 'none';
            const dl = document.getElementById('dl');
            dl.href = url;
            document.getElementById('dl-filename').textContent = url.split('/').pop() || 'hippos-amd64.img.zst';
            dl.style.display = 'flex';
            if (uploadedAt) {
              const d = document.getElementById('upload-date');
              d.textContent = `Uploaded ${new Date(uploadedAt).toLocaleString(undefined, { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' })}`;
              d.style.display = 'block';
            }
          } else {
            err.style.display = 'block';
            btn.disabled = false;
            btn.textContent = 'Get Download Link';
          }
        } catch {
          err.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Get Download Link';
        }
      });
    }
  </script>
