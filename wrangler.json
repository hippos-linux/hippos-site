{
	"name": "hippos-site",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"r2_buckets": [
		{
			"binding": "HIPPOS_IMAGES",
			"bucket_name": "hippos-images"
		}
	],
	"vars": {
		"DISCORD_CLIENT_ID": "1511440736195711016",
		"DISCORD_REDIRECT_URI": "https://hippos-linux.org/api/auth/callback",
		"DISCORD_GUILD_ID": "1509632863903940719",
		"DISCORD_REQUIRED_ROLE_ID": "1511469773664288848"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
